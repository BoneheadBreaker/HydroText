<Window x:Class="HydroText.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HydroText"
        mc:Ignorable="d"
        Title="Hydro Text" Height="450" Width="800">
    <Grid Background="#FF1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="33*"/>
            <RowDefinition Height="401*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="13*"/>
            <ColumnDefinition Width="187*"/>
        </Grid.ColumnDefinitions>
        <RichTextBox x:Name="MainTextBox" Grid.Row="1" Grid.ColumnSpan="2" Background="#FF252525" Foreground="White" Margin="10,10,10,10">
            <FlowDocument>
                <Paragraph>
                    <Run Text=""/>
                </Paragraph>
            </FlowDocument>
        </RichTextBox>
        <DockPanel Background="#FF191919" LastChildFill="False" Grid.ColumnSpan="2" Margin="0,0,0,3"/>
        <Menu Background="#FF191919" Grid.ColumnSpan="2">
            <MenuItem x:Name="FileMenu" Header="File" FontSize="20" Foreground="White">
                <MenuItem x:Name="OpenFolder" Header="Open" Click="OpenFile_Click" FontSize="12" Foreground="White" Background="Black"/>
                <MenuItem x:Name="SaveFolder" Header="Save" Background="Black" Foreground="White" Click="SaveFolder_Click"/>
                <MenuItem x:Name="SaveAsFolder" Header="Save As" Click="SaveAsFolder_Click" Background="Black" Foreground="White"/>
            </MenuItem>
            <ToggleButton Command="EditingCommands.ToggleBold" CommandTarget="{Binding ElementName=rtbEditor}" HorizontalAlignment="Right" VerticalAlignment="Top" Foreground="#FF191919">
                <TextBlock FontWeight="Bold"><Run Text="B"/></TextBlock>
            </ToggleButton>
            <ToggleButton Command="EditingCommands.ToggleItalic" CommandTarget="{Binding ElementName=rtbEditor}" HorizontalAlignment="Right" VerticalAlignment="Top" Foreground="#FF191919">
                <TextBlock FontStyle="Italic"><Run Text="I"/></TextBlock>
            </ToggleButton>
            <ToggleButton Command="EditingCommands.ToggleUnderline" CommandTarget="{Binding ElementName=rtbEditor}" HorizontalAlignment="Right" VerticalAlignment="Top" Foreground="#FF191919">
                <TextBlock TextDecorations="Underline"><Run Text="U"/></TextBlock>
            </ToggleButton>
        </Menu>

    </Grid>
</Window>
